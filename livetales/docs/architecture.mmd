    style GCS fill:#d1fae5,stroke:#10b981,stroke-width:2px
    style LiveVoice fill:#fce7f3,stroke:#ec4899,stroke-width:1px
    style StoryPipeline fill:#fff7ed,stroke:#f97316,stroke-width:1px
    style VideoPipeline fill:#e0f2fe,stroke:#0284c7,stroke-width:1px
    style TransBuf fill:#fef9c3,stroke:#ca8a04,stroke-width:1px
